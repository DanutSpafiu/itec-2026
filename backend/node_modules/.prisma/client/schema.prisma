generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. UTILIZATORI
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String // Parolă hash-uită (ex: bcrypt)
  name     String

  // Utilizatorul poate sau nu să fie într-o echipă curent.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  // Desenele făcute DOAR de acest utilizator
  graffitis Graffiti[]

  createdAt DateTime @default(now())
}

// 2. ECHIPE (Logica de "Maxim 4 utilizatori" se face din Node.js)
model Team {
  id       String @id @default(uuid())
  name     String @unique
  joinCode String @unique // ex: "X7F9A"

  members   User[]
  createdAt DateTime @default(now())
}

// 3. AFIȘE (Baza de imagini pe care aplicația - ARKit/ARCore le recunoaște vizual, folosind Modelul CV)
model Poster {
  id             String @id @default(uuid())
  name           String // ex: "Afiș intrare ITEC"
  referenceImage String // URL-ul pozei pentru AI-ul de pe telefon

  // AICI NU MAI SUNT COORDONATE (GPS), detectarea e pur vizuală (Image Tracking)

  graffitis Graffiti[]
}

// 4. GRAFFITI (Desenele AR efective)
model Graffiti {
  id String @id @default(uuid())

  // NOU: Legat doar de utilizatorul efectiv, nu de echipa globală
  userId String
  user   User   @relation(fields: [userId], references: [id])

  posterId String
  poster   Poster @relation(fields: [posterId], references: [id])

  // ATENȚIE: Acestea nu sunt coordonate logice/geografice de recunoaștere a afișului.
  // Acesta este JSON-ul care memorează vectorii mișcărilor DEGETELOR (X, Y) raportate pe lungimea Afișului.
  // Fără astea, desenul pur și simplu nu are o structură dinamică ce poate fi trimisă online.
  linesData Json
  color     String @default("#000000") // HEX code like #FF6B6B
  size      Int    @default(4) // Thickness of the line

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
